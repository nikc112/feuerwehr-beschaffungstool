# Kopiere diese Datei zu ".env" und passe die Werte an.

# Sicherheitsschlüssel (bitte langen Zufallswert eingeben!)
SECRET_KEY=bitte-aendern-mit-langem-zufallswert

# Datenverzeichnis (Standard für Docker: /app/data, für lokale Entwicklung: ./data)
DATA_DIR=/app/data

# SMTP-Konfiguration für E-Mail-Versand
SMTP_HOST=smtp.example.de
SMTP_PORT=587
SMTP_USER=wehrfuehrung@feuerwehr-moorrege.de
SMTP_PASSWORD=
SMTP_FROM=Freiwillige Feuerwehr Moorrege <wehrfuehrung@feuerwehr-moorrege.de>
# SMTP_TLS=true für STARTTLS (Port 587), SMTP_TLS=false für SSL (Port 465)
SMTP_TLS=true
