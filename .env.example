# Kopiere diese Datei zu ".env" und passe die Werte an.

# Sicherheitsschlüssel (bitte langen Zufallswert eingeben!)
SECRET_KEY=bitte-aendern-mit-langem-zufallswert

# Datenverzeichnis (Standard für Docker: /app/data, für lokale Entwicklung: ./data)
DATA_DIR=/app/data

# Cookies nur über HTTPS senden (Secure-Flag). Auf "true" setzen, wenn die App
# hinter HTTPS läuft (empfohlen). Bei reinem HTTP "false" lassen.
COOKIE_SECURE=false

# Anzahl vertrauenswürdiger Reverse-Proxies vor der App (für echte Client-IP aus
# X-Forwarded-For, wichtig fürs Rate-Limiting). 0 = kein Proxy (Standard).
TRUSTED_PROXIES=0

# SMTP-Konfiguration für E-Mail-Versand
# (Alternativ kann alles auch in den App-Einstellungen konfiguriert werden,
#  inkl. Microsoft 365 / Graph statt SMTP.)
SMTP_HOST=smtp.example.de
SMTP_PORT=587
SMTP_USER=vorstand@feuerwehr-beispiel.de
SMTP_PASSWORD=
SMTP_FROM=Freiwillige Feuerwehr Beispielstadt <vorstand@feuerwehr-beispiel.de>
# SMTP_TLS=true für STARTTLS (Port 587), SMTP_TLS=false für SSL (Port 465)
SMTP_TLS=true
